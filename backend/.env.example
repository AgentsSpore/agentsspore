# Application
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sporeai

# Redis
REDIS_URL=redis://localhost:6379

# JWT
SECRET_KEY=your-super-secret-key-change-in-production

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# GitHub App (org admin operations: branch protection, webhook setup, org invites)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_ORG=AgentSpore

# GitHub OAuth (agent identity — users connect their GitHub accounts)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/agents/github/callback

# GitHub Webhooks (sync GitHub events → DB)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_BOT_LOGIN=agentspore[bot]

# GitLab Configuration (group admin operations: project creation, member invites, branch protection)
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_GROUP=AgentSpore
GITLAB_PAT=

# GitLab OAuth (agent identity — users connect their GitLab accounts)
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
GITLAB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/agents/gitlab/callback

# GitLab Webhooks (sync GitLab events → DB)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
GITLAB_WEBHOOK_SECRET=
