# AgentSpore - Environment Variables
# Copy this file to .env and fill in the values

# ========================================
# LLM Provider (OpenRouter)
# ========================================
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
LLM_API_KEY=sk-or-v1-...

# Default model (for reddit_bot and other agents without ModelPool)
LLM_MODEL=anthropic/claude-sonnet-4-5

# ========================================
# Agent Model Tiers (ModelPool)
# ========================================
# fast     — shallow file scan, chat messages (cheap)
# standard — regular code review (default)
# strong   — security review and deep analysis (powerful)
LLM_MODEL_FAST=z-ai/glm-5
LLM_MODEL_STANDARD=anthropic/claude-sonnet-4-5
LLM_MODEL_STRONG=anthropic/claude-sonnet-4-6

# CodeReviewerAgent schedule
REVIEWER_REVIEW_INTERVAL_HOURS=2
REVIEWER_HEARTBEAT_INTERVAL_HOURS=4
REVIEWER_MAX_PROJECTS=3

# DeveloperAgent schedule
DEVELOPER_WORK_INTERVAL_HOURS=1
DEVELOPER_HEARTBEAT_INTERVAL_HOURS=4
DEVELOPER_MAX_ISSUES=5

# RedditScout schedule
REDDIT_DISCOVER_INTERVAL_HOURS=6
REDDIT_HEARTBEAT_INTERVAL_HOURS=4

# ========================================
# JWT Security
# ========================================
# Generate: openssl rand -hex 32
SECRET_KEY=78c27bef590374feb1002177e9b8923b35c02bea4336ff458ade2fd028a266b0

# ========================================
# Database (default for Docker)
# ========================================
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/sporeai

# ========================================
# Debug Mode
# ========================================
DEBUG=true

# ========================================
# Web3 / Base mainnet (ERC-20 ownership)
# ========================================
# Oracle wallet private key (hex, 0x-prefixed) — AgentSpore backend mints tokens
ORACLE_PRIVATE_KEY=0x...

# Base RPC URL (default: public mainnet)
BASE_RPC_URL=https://mainnet.base.org

# Factory contract address (from: forge script Deploy.s.sol --broadcast)
FACTORY_CONTRACT_ADDRESS=0x...

# BaseScan API key (for contract verification)
BASESCAN_API_KEY=...

# ========================================
# Render (auto-deploy projects to render.com)
# ========================================
# Get API key at https://render.com → Account Settings → API Keys
RENDER_API_KEY=rnd_...
# Owner ID: curl -H "Authorization: Bearer rnd_..." https://api.render.com/v1/owners
RENDER_OWNER_ID=tea-...
